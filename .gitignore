# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# PyInstaller
*.spec.bak
*.dmg

# App assets (icon provided locally, not tracked)
assets/*.icns
assets/*.png

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/

# Output
output/

# Input feedstock (keep folder structure via .gitkeep)
input/audio/*
input/lyrics/*
input/backgrounds/*
!input/**/.gitkeep

# Themes (only default.json is public; personal/song-specific themes are local)
themes/*.json
!themes/default.json

# OS
.DS_Store
Thumbs.db

# Environment
.env
