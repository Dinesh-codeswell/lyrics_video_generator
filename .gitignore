# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# PyInstaller
*.spec.bak
*.dmg

# App assets (PNG excluded; .icns is tracked so CI builds can find it)
assets/*.png

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/

# Claude Code local session files (contain personal paths and permissions)
.claude/

# Web
web/node_modules/
web/dist/

# Output
output/
*.mp4

# Input feedstock (keep folder structure via .gitkeep)
input/audio/*
input/lyrics/*
# Allow background presets to be tracked for production deployment
input/backgrounds/.gitkeep
!input/backgrounds/*.mp4
!input/backgrounds/*.mov
!input/backgrounds/*.avi
!input/backgrounds/*.mkv
!input/backgrounds/*.webm

# Still ignore specifically uploaded ones if we want to differentiate (optional)
# For now, we allow everything in backgrounds to ensure your 6 presets show up.
!input/**/.gitkeep

# Themes (only default.json is public; personal/song-specific themes are local)
themes/*.json
!themes/default.json

# OS
.DS_Store
Thumbs.db

# Environment
.env

# Worktrees
.worktrees/
